# Resend Email API — https://resend.com
# 1. Sign up at resend.com (free — 100 emails/day)
# 2. Create an API key at https://resend.com/api-keys
# 3. Copy this file to .env.local and fill in the values
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The "From" address for enquiry emails
# For testing: use "SkyVDO Entertainment <onboarding@resend.dev>"
# For production: verify your domain at https://resend.com/domains
#   then use something like "SkyVDO Entertainment <noreply@skyvdo.com>"
RESEND_FROM_EMAIL=SkyVDO Entertainment <onboarding@resend.dev>

# The email address that receives enquiry notifications
ENQUIRY_EMAIL=hello@skyvdo.com
