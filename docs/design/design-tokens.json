{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "sundown": {
    "color": {
      "primitive": {
        "midnight": { "$value": "#0A0E1A", "$type": "color", "$description": "Deepest background" },
        "deep-navy": { "$value": "#111827", "$type": "color", "$description": "Elevated surface" },
        "slate-blue": { "$value": "#1E293B", "$type": "color", "$description": "Secondary surface" },
        "twilight-purple": { "$value": "#312E81", "$type": "color", "$description": "Gradient accent" },
        "amber-glow": { "$value": "#F59E0B", "$type": "color", "$description": "Primary accent" },
        "sunset-orange": { "$value": "#EA580C", "$type": "color", "$description": "Warm accent" },
        "cinema-red": { "$value": "#DC2626", "$type": "color", "$description": "Bold promo accent" },
        "starlight": { "$value": "#F1F5F9", "$type": "color", "$description": "Primary text on dark" },
        "moonstone": { "$value": "#94A3B8", "$type": "color", "$description": "Secondary text" },
        "dusk": { "$value": "#475569", "$type": "color", "$description": "Muted / disabled text" },
        "screen-white": { "$value": "#FFFFFF", "$type": "color", "$description": "Pure white for projector screen elements" },
        "success": { "$value": "#10B981", "$type": "color", "$description": "Positive states" },
        "error": { "$value": "#EF4444", "$type": "color", "$description": "Error states" }
      },
      "semantic": {
        "bg-primary": { "$value": "{sundown.color.primitive.midnight}", "$type": "color" },
        "bg-surface": { "$value": "{sundown.color.primitive.deep-navy}", "$type": "color" },
        "bg-surface-alt": { "$value": "{sundown.color.primitive.slate-blue}", "$type": "color" },
        "bg-accent": { "$value": "{sundown.color.primitive.amber-glow}", "$type": "color" },
        "bg-accent-warm": { "$value": "{sundown.color.primitive.sunset-orange}", "$type": "color" },
        "bg-promo": { "$value": "{sundown.color.primitive.cinema-red}", "$type": "color" },
        "text-primary": { "$value": "{sundown.color.primitive.starlight}", "$type": "color" },
        "text-secondary": { "$value": "{sundown.color.primitive.moonstone}", "$type": "color" },
        "text-muted": { "$value": "{sundown.color.primitive.dusk}", "$type": "color" },
        "text-accent": { "$value": "{sundown.color.primitive.amber-glow}", "$type": "color" },
        "text-on-accent": { "$value": "{sundown.color.primitive.midnight}", "$type": "color" },
        "border-subtle": { "$value": "rgba(255, 255, 255, 0.06)", "$type": "color" },
        "border-default": { "$value": "rgba(255, 255, 255, 0.10)", "$type": "color" },
        "border-accent": { "$value": "{sundown.color.primitive.amber-glow}", "$type": "color" },
        "focus-ring": { "$value": "{sundown.color.primitive.amber-glow}", "$type": "color" },
        "state-success": { "$value": "{sundown.color.primitive.success}", "$type": "color" },
        "state-error": { "$value": "{sundown.color.primitive.error}", "$type": "color" }
      }
    },
    "typography": {
      "font-family": {
        "display": { "$value": "'Bebas Neue', Impact, sans-serif", "$type": "fontFamily" },
        "body": { "$value": "'Outfit', system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
        "mono": { "$value": "'JetBrains Mono', 'Fira Code', monospace", "$type": "fontFamily" }
      },
      "font-size": {
        "display-xl": { "$value": "4.5rem", "$type": "dimension", "$description": "72px — Hero headlines" },
        "display-lg": { "$value": "3.5rem", "$type": "dimension", "$description": "56px — Section heroes" },
        "display-md": { "$value": "2.5rem", "$type": "dimension", "$description": "40px — Card headlines" },
        "heading-lg": { "$value": "1.75rem", "$type": "dimension", "$description": "28px — Section headings" },
        "heading-md": { "$value": "1.375rem", "$type": "dimension", "$description": "22px — Subsection headings" },
        "heading-sm": { "$value": "1.125rem", "$type": "dimension", "$description": "18px — Card titles" },
        "body-lg": { "$value": "1.125rem", "$type": "dimension", "$description": "18px — Lead text" },
        "body-md": { "$value": "1rem", "$type": "dimension", "$description": "16px — Default body" },
        "body-sm": { "$value": "0.875rem", "$type": "dimension", "$description": "14px — Captions" },
        "label": { "$value": "0.75rem", "$type": "dimension", "$description": "12px — Button labels, tags" },
        "mono": { "$value": "1rem", "$type": "dimension", "$description": "16px — Pricing, specs" }
